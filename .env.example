# System Settings
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=supersecretjwtkeychangeinproduction
JWT_REFRESH_SECRET=supersecretjwtrefreshkeychangeinproduction
JWT_EXPIRES_IN=15m

# Shared Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=saas_platform

# Cache and Session (Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Stripe Billing Settings
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# AWS Services Config
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mock-key-id
AWS_SECRET_ACCESS_KEY=mock-secret-key
AWS_SQS_PROVISIONING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/tenant-provisioning-queue
AWS_SES_FROM_EMAIL=noreply@saas.example.com
AWS_LAMBDA_PROVISION_NAME=provision-tenant

# WebSockets Configuration
SOCKET_PORT=5001
